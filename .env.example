# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=你的_Channel_Access_Token
LINE_CHANNEL_SECRET=你的_Channel_Secret

# Anthropic Claude API
ANTHROPIC_API_KEY=你的_Anthropic_API_Key

# 定時推播的群組 ID（可先留空，取得後再填）
LINE_GROUP_ID=

# PostgreSQL 連線（Zeabur 建立 PostgreSQL 後自動注入）
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Perplexity API（網路搜尋用）
PERPLEXITY_API_KEY=你的_Perplexity_API_Key

# Google Calendar（選填，免費）
# 將 Service Account JSON 內容貼入（單行）
GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account",...}
GOOGLE_CALENDAR_ID=你的日曆ID@gmail.com
